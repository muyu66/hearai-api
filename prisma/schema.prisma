generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum PronunciationType {
  // 英式发音
  UK
  // 美式发音
  US
}

/// 英文->音标->中文->英文
enum QuestionMode {
  WORD_TO_TRAN // 学习模式
  WORD_TO_SOUND // 复习模式
  SOUND_TO_TRAN // 复习模式
  TRAN_TO_WORD // 复习模式
}

/// 用户表
model User {
  id             BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  username       String            @unique @db.VarChar(50)
  nickname       String            @default("") @db.VarChar(100)
  /// 单词难度等级
  wordLevel      Int               @default(0) @map("word_level") @db.UnsignedTinyInt
  /// 每日单词任务数量
  dailyWordCount Int               @default(0) @map("daily_word_count") @db.UnsignedSmallInt
  /// 发音类型
  pronType       PronunciationType @map("pron_type")

  wechatOpenid String? @unique @map("wechat_openid") @db.VarChar(255)
  googleOpenid String? @unique @map("google_openid") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  @@map("users")
}

/// 单词表
model Word {
  id              BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  word            String  @db.VarChar(200)
  translation     String  @db.VarChar(1000)
  /// 英式音标
  ukPhonetic      String  @map("uk_phonetic") @db.VarChar(255)
  /// 美式音标
  usPhonetic      String  @map("us_phonetic") @db.VarChar(255)
  /// 英式音标发音地址
  ukPronunciation String? @map("uk_pronunciation") @db.VarChar(255)
  /// 美式音标发音地址
  usPronunciation String? @map("us_pronunciation") @db.VarChar(255)
  level           Int     @default(1) @map("level") @db.UnsignedTinyInt

  /// 易混淆的单词
  confusedWords        Json? @map("confused_words")
  /// 易混淆的中文释义
  confusedTranslations Json? @map("confused_translations")
  /// 易混淆的英式单词音标发音
  confusedUkPhonetics  Json? @map("confused_uk_phonetics")
  /// 易混淆的美式式单词音标发音
  confusedUsPhonetics  Json? @map("confused_us_phonetics")

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  dailyTaskWords DailyTaskWord[]

  /// 同一单词只能有一条记录
  @@unique(word)
  @@map("words")
}

/// 用户自定义的单词
model UserCustomWord {
  id        BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt  @map("user_id") @db.UnsignedBigInt
  word      String  @db.VarChar(200)
  /// 用户上报的单词是否已支持在字典里
  supported Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  /// 同一用户同一单词只能有一条记录
  @@unique([userId, word])
  @@map("user_custom_words")
}

/// 每日推送任务
model DailyTask {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt    @map("user_id") @db.UnsignedBigInt
  /// 任务数量
  taskCount  Int       @default(0) @map("task_count") @db.UnsignedSmallInt
  /// 本任务是否完成过
  isFinished Boolean   @default(false) @map("is_finished")
  finishedAt DateTime? @map("finished_at") @db.DateTime(0)

  createdDate String @map("created_date") @db.VarChar(10)

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  dailyTaskWords DailyTaskWord[]

  /// 同一用户同一天只能有一条记录
  @@unique([userId, createdDate])
  @@map("daily_tasks")
}

/// 每日推送任务单词
model DailyTaskWord {
  id           BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  dailyTaskId  BigInt       @map("daily_task_id") @db.UnsignedBigInt
  userId       BigInt       @map("user_id") @db.UnsignedBigInt
  wordId       BigInt       @map("word_id") @db.UnsignedBigInt
  questionMode QuestionMode @map("question_mode")
  /// 选错的次数
  failedCount  Int          @default(0) @map("failed_count") @db.UnsignedTinyInt
  /// 思考时间 单位ms
  thinkingTime Int          @default(0) @map("thinking_time") @db.UnsignedInt
  /// 本单词任务是否已经掌握
  master       Boolean      @default(false)

  /// 本单词任务是否完成过
  isFinished Boolean   @default(false) @map("is_finished")
  finishedAt DateTime? @map("finished_at") @db.DateTime(0)

  createdDate String @map("created_date") @db.VarChar(10)

  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  word      Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  dailyTask DailyTask @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)

  /// 同一任务同一单词同一题型只能有一条记录
  @@unique([dailyTaskId, wordId, questionMode])
  /// 同一用户同一天同一单词同一题型只能有一条记录 (同一用户同一天 = 同一任务)
  @@unique([userId, wordId, createdDate, questionMode])
  @@map("daily_task_words")
}
